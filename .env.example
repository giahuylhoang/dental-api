# Google Workspace SMTP relay (see clients/email_client.py)
SMTP_HOST=smtp-relay.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
# EHLO identity for STARTTLS (omit or set to your domain when using IP-based relay without AUTH)
SMTP_LOCAL_HOSTNAME=rockyridgeai.com
SMTP_USER=you@rockyridgeai.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=notifications@rockyridgeai.com
EMAIL_FROM_NAME=RockyRidge Notifications

# Optional: set on Cloud Run so a test email is sent at startup; process exits 1 if send fails
# SMTP_DEPLOY_VERIFY_TO=you@rockyridgeai.com

# Optional: send all new-booking clinic emails here (overrides clinic.booking_notification_email).
# Leave unset in production so each clinic uses PATCH /api/clinics/me booking_notification_email.


# Shared secret for internal (non-user) callers of get_internal_caller — the booking
# BFF and the voice agent (Emma) present this as X-Internal-Secret to reach
# POST /api/public/holds. Also signs the patient self-confirm token. MUST match the
# value set on the BFF and dental-agent services.
DENTAL_API_INTERNAL_SECRET=change-me-to-a-long-random-string
