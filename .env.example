# Google Workspace SMTP relay (see clients/email_client.py)
SMTP_HOST=smtp-relay.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
# EHLO identity for STARTTLS (omit or set to your domain when using IP-based relay without AUTH)
SMTP_LOCAL_HOSTNAME=rockyridgeai.com
SMTP_USER=you@rockyridgeai.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=notifications@rockyridgeai.com
EMAIL_FROM_NAME=RockyRidge Notifications

# Optional: set on Cloud Run so a test email is sent at startup; process exits 1 if send fails
# SMTP_DEPLOY_VERIFY_TO=you@rockyridgeai.com

# Optional: send all new-booking clinic emails here (overrides clinic.booking_notification_email).
# Leave unset in production so each clinic uses PATCH /api/clinics/me booking_notification_email.


# Shared secret for internal (non-user) callers of get_internal_caller — the booking
# BFF and the voice agent (Emma) present this as X-Internal-Secret to reach
# POST /api/public/holds. Also signs the patient self-confirm token. MUST match the
# value set on the BFF and dental-agent services.
DENTAL_API_INTERNAL_SECRET=change-me-to-a-long-random-string

# --- SMS provider selection ---
# telnyx | twilio. Default twilio. Flip to telnyx after the Telnyx
# number is provisioned and tested. Rollback = flip back to twilio.
SMS_PROVIDER=twilio

# --- Telnyx Messaging (required when SMS_PROVIDER=telnyx) ---
TELNYX_API_KEY=
TELNYX_MESSAGING_PROFILE_ID=
TELNYX_SMS_FROM_NUMBER=
# Ed25519 public key (base64) from the Messaging Profile webhook config.
# Used by POST /webhooks/telnyx/sms-inbound to verify Telnyx-Signature-ED25519.
TELNYX_PUBLIC_KEY=

# --- SMS reminder scheduler (Phase B) ---
REMINDER_OFFSET_HOURS=24            # hours before appointment to send reminder
QUIET_HOURS_START=21                # clinic-local hour reminders are deferred FROM
QUIET_HOURS_END=8                   # clinic-local hour reminders resume AT
MIN_LEAD_MINUTES=30                 # skip if reminder would land <N min before appt
# Optional: enable Gemini Flash fallback for ambiguous SMS replies.
SMS_REPLY_LLM_FALLBACK=false
# Public base URL of dental-api for building reschedule links inside SMS bodies.
DENTAL_API_PUBLIC_BASE_URL=https://api.example.com
# Base URL of market-mall-website (handles the reschedule UX).
MARKET_MALL_WEBSITE_BASE_URL=https://marketmall.example.com
# Ed25519 signing key (base64 seed) used to sign the reschedule session blob
# handed off to market-mall-website. Public half is shared with the BFF.
RESCHEDULE_SESSION_SIGNING_KEY=
